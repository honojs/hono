{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "declaration": true,
    "moduleResolution": "Bundler",
    "outDir": "${configDir}/dist",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  }
}
